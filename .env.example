# Local mock mode for testing the HTTP wrapper without model credentials.
PI_MOCK=1

# pi runtime args. The server removes --no-session and adds a session-specific
# --continue --session-dir when handling invocations.
PI_ARGS=--mode rpc --no-session
REQUEST_TIMEOUT_MS=300000
ENABLE_DIAGNOSTICS=0

# Foundry OpenAI-compatible endpoint used to generate pi's custom `foundry`
# provider in PI_CODING_AGENT_DIR/models.json.
#
# Replace these placeholders with your Foundry/account values. For Hosted Agent
# sandbox execution, the account-level cognitiveservices endpoint is often safer
# than a project-scoped services.ai.azure.com/openai endpoint.
PI_OPENAI_BASE_URL=https://<account>.cognitiveservices.azure.com/openai/v1
PI_OPENAI_MODEL=<foundry-model-or-deployment>
# PI_OPENAI_API_KEY=

# Real model credentials, depending on your pi model/provider config.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
